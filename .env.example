DATABASE_URL=postgresql://user:password@localhost:5432/opecvar
# IMPORTANTE: Em producao, use um secret aleatorio de pelo menos 32 caracteres
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-secret-key-here-min-32-chars
PORT=3001
JWT_EXPIRES_IN=7d
NODE_ENV=development
# Origens permitidas (separadas por virgula)
# ALLOWED_ORIGINS=https://meusite.com,https://admin.meusite.com

# SMTP Config (para notificacoes por email)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=sua-senha-de-app
# SMTP_FROM=OPECVAR <seuemail@gmail.com>
